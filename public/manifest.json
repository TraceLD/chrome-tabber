{
  "manifest_version": 3,
  "name": "Tabber",
  "version": "1.0",
  "description": "Fuzzy find and switch tabs with a keyboard shortcut",
  "permissions": ["tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabber"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Open tab finder"
    }
  }
}
